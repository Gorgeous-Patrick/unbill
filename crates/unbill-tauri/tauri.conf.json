{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "unbill",
  "identifier": "computer.unbill",
  "build": {
    "beforeDevCommand": {
      "cwd": "../../apps/unbill-ui-leptos",
      "script": "trunk serve --config Trunk.toml --address 0.0.0.0",
      "wait": false
    },
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": {
      "cwd": "../../apps/unbill-ui-leptos",
      "script": "trunk build --config Trunk.toml --release"
    },
    "frontendDist": "../../apps/unbill-ui-leptos/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "unbill",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "iOS": {
      "developmentTeam": "BB577FKUK4",
      "frameworks": ["SystemConfiguration"],
      "template": "ios/project.yml"
    },
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
